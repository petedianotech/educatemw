{
  "name": "educate-mw",
  "version": "1.0.0",
  "author": "Peter Leo Damiano",
  "description": "A premium educational ecosystem for students in Malawi.",
  "scripts": {
    "ng": "ng",
    "start": "ng serve",
    "dev": "cross-env ng serve --port=3000 --host=0.0.0.0 --define=\"GEMINI_API_KEY=\\'${GEMINI_API_KEY}\\'\" ${DISABLE_HMR:+--live-reload=false}",
    "build": "cross-env ng build --define=\"GEMINI_API_KEY=\\'${GEMINI_API_KEY}\\'\"",
    "watch": "ng build --watch --configuration development",
    "test": "ng test",
    "lint": "ng lint",
    "serve:ssr:app": "node dist/app/server/server.mjs",
    "generate:assets": "capacitor-assets generate"
  },
  "private": true,
  "dependencies": {
    "@angular/cdk": "^21.0.0",
    "@angular/common": "^21.0.0",
    "@angular/compiler": "^21.0.0",
    "@angular/core": "^21.0.0",
    "@angular/forms": "^21.0.0",
    "@angular/material": "^21.0.0",
    "@angular/platform-browser": "^21.0.0",
    "@angular/platform-server": "^21.0.0",
    "@angular/router": "^21.0.0",
    "@angular/service-worker": "^21.2.8",
    "@angular/ssr": "^21.0.0",
    "@capacitor/android": "^8.3.0",
    "@capacitor/browser": "^8.0.3",
    "@capacitor/cli": "^8.3.0",
    "@capacitor/core": "^8.3.0",
    "@capacitor/status-bar": "^8.0.2",
    "@google/genai": "^1.27.0",
    "express": "^5.1.0",
    "firebase": "^12.11.0",
    "idb": "^8.0.3",
    "marked": "^18.0.0",
    "recharts": "^3.8.1",
    "rxjs": "~7.8.0",
    "tslib": "^2.3.0"
  },
  "devDependencies": {
    "@angular/build": "^21.0.0",
    "@angular/cli": "^21.0.0",
    "@angular/compiler-cli": "^21.0.0",
    "@capacitor/assets": "^3.0.5",
    "@tailwindcss/postcss": "^4.1.12",
    "@types/express": "^5.0.1",
    "@types/marked": "^5.0.2",
    "@types/node": "^20.17.19",
    "angular-eslint": "21.1.0",
    "cross-env": "^10.1.0",
    "eslint": "^9.39.1",
    "jsdom": "^27.0.0",
    "postcss": "^8.5.3",
    "tailwindcss": "^4.1.12",
    "typescript": "~5.9.2",
    "typescript-eslint": "8.47.0",
    "vitest": "^4.0.0"
  }
}
