{
  "entities": {
    "User": {
      "title": "User",
      "description": "A user of the educational platform.",
      "type": "object",
      "properties": {
        "uid": { "type": "string", "description": "The user's unique ID." },
        "email": { "type": "string", "format": "email" },
        "displayName": { "type": "string" },
        "photoURL": { "type": "string", "format": "uri" },
        "role": { "type": "string", "enum": ["student", "admin"] },
        "isPro": { "type": "boolean", "description": "Whether the user has Pro access." },
        "aiCredits": { "type": "number", "description": "Remaining AI credits." },
        "streak": { "type": "number", "description": "Current daily streak." },
        "coins": { "type": "number", "description": "User's virtual currency." },
        "pwaInstalled": { "type": "boolean", "description": "Whether the user has installed the PWA." },
        "referralCode": { "type": "string", "description": "Unique code for referrals." },
        "referredBy": { "type": "string", "description": "UID of the user who referred this user." },
        "referralsCount": { "type": "number", "description": "Number of successful referrals." },
        "fcmToken": { "type": "string", "description": "Firebase Cloud Messaging token for push notifications." },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "email", "role", "isPro", "createdAt"]
    },
    "FlashcardSet": {
      "title": "FlashcardSet",
      "description": "A set of flashcards.",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "description": { "type": "string" },
        "category": { "type": "string" },
        "authorId": { "type": "string" },
        "authorName": { "type": "string" },
        "isProOnly": { "type": "boolean" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["title", "category", "authorId", "authorName", "isProOnly", "createdAt"]
    },
    "Flashcard": {
      "title": "Flashcard",
      "description": "A single flashcard within a set.",
      "type": "object",
      "properties": {
        "setId": { "type": "string" },
        "front": { "type": "string" },
        "back": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["setId", "front", "back", "createdAt"]
    },
    "Post": {
      "title": "Post",
      "description": "A community forum post.",
      "type": "object",
      "properties": {
        "authorId": { "type": "string" },
        "authorName": { "type": "string" },
        "authorPhoto": { "type": "string", "format": "uri" },
        "content": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "likesCount": { "type": "number" },
        "commentsCount": { "type": "number" }
      },
      "required": ["authorId", "authorName", "content", "createdAt", "likesCount", "commentsCount"]
    },
    "Comment": {
      "title": "Comment",
      "description": "A comment on a community post.",
      "type": "object",
      "properties": {
        "postId": { "type": "string" },
        "authorId": { "type": "string" },
        "authorName": { "type": "string" },
        "authorPhoto": { "type": "string", "format": "uri" },
        "content": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["postId", "authorId", "authorName", "content", "createdAt"]
    },
    "Quiz": {
      "title": "Quiz",
      "description": "An educational quiz.",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "description": { "type": "string" },
        "category": { "type": "string" },
        "authorId": { "type": "string", "description": "The user who created the quiz." },
        "timeLimit": { "type": "number", "description": "Time limit in minutes." },
        "isProOnly": { "type": "boolean" },
        "questions": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "text": { "type": "string" },
              "type": { "type": "string", "enum": ["multiple-choice", "true-false"] },
              "options": { "type": "array", "items": { "type": "string" } },
              "correctAnswer": { "type": "string" }
            },
            "required": ["text", "type", "correctAnswer"]
          }
        },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["title", "category", "authorId", "timeLimit", "isProOnly", "questions", "createdAt"]
    },
    "QuizResult": {
      "title": "QuizResult",
      "description": "A student's result on a quiz.",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "quizId": { "type": "string" },
        "score": { "type": "number" },
        "total": { "type": "number" },
        "completedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "quizId", "score", "total", "completedAt"]
    },
    "Note": {
      "title": "Note",
      "description": "An educational note or past paper.",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "content": { "type": "string" },
        "category": { "type": "string" },
        "isProOnly": { "type": "boolean" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["title", "content", "category", "isProOnly", "createdAt"]
    },
    "AppUpdate": {
      "title": "AppUpdate",
      "description": "An update announcement for the application.",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "content": { "type": "string" },
        "type": { "type": "string", "enum": ["feature", "maintenance", "announcement"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["title", "content", "type", "createdAt"]
    },
    "RevenueRecord": {
      "title": "RevenueRecord",
      "description": "A record of a premium subscription purchase.",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "userName": { "type": "string" },
        "amount": { "type": "number" },
        "plan": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "userName", "amount", "plan", "createdAt"]
    },
    "ExamDate": {
      "title": "ExamDate",
      "description": "An upcoming exam date.",
      "type": "object",
      "properties": {
        "subject": { "type": "string" },
        "date": { "type": "string", "format": "date-time" },
        "description": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["subject", "date", "createdAt"]
    },
    "ChatMessage": {
      "title": "ChatMessage",
      "description": "A message in the community chat.",
      "type": "object",
      "properties": {
        "authorId": { "type": "string" },
        "authorName": { "type": "string" },
        "authorPhoto": { "type": "string", "format": "uri" },
        "content": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["authorId", "authorName", "content", "createdAt"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": { "$ref": "#/entities/User" },
      "description": "User profiles."
    },
    "/messages/{messageId}": {
      "schema": { "$ref": "#/entities/ChatMessage" },
      "description": "Community chat messages."
    },
    "/posts/{postId}": {
      "schema": { "$ref": "#/entities/Post" },
      "description": "Community posts."
    },
    "/posts/{postId}/comments/{commentId}": {
      "schema": { "$ref": "#/entities/Comment" },
      "description": "Comments on a post."
    },
    "/quizzes/{quizId}": {
      "schema": { "$ref": "#/entities/Quiz" },
      "description": "Educational quizzes."
    },
    "/quizResults/{resultId}": {
      "schema": { "$ref": "#/entities/QuizResult" },
      "description": "Student quiz results."
    },
    "/notes/{noteId}": {
      "schema": { "$ref": "#/entities/Note" },
      "description": "Educational notes and past papers."
    },
    "/appUpdates/{updateId}": {
      "schema": { "$ref": "#/entities/AppUpdate" },
      "description": "Application update announcements."
    },
    "/revenue/{recordId}": {
      "schema": { "$ref": "#/entities/RevenueRecord" },
      "description": "Revenue records for premium subscriptions."
    },
    "/examDates/{dateId}": {
      "schema": { "$ref": "#/entities/ExamDate" },
      "description": "Upcoming exam dates."
    },
    "/flashcardSets/{setId}": {
      "schema": { "$ref": "#/entities/FlashcardSet" },
      "description": "Flashcard sets."
    },
    "/flashcards/{cardId}": {
      "schema": { "$ref": "#/entities/Flashcard" },
      "description": "Individual flashcards."
    }
  }
}
