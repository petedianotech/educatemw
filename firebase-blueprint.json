{
  "entities": {
    "User": {
      "title": "User",
      "description": "A user of the educational platform.",
      "type": "object",
      "properties": {
        "uid": { "type": "string", "description": "The user's unique ID." },
        "email": { "type": "string", "format": "email" },
        "displayName": { "type": "string" },
        "photoURL": { "type": "string", "format": "uri" },
        "role": { "type": "string", "enum": ["student", "admin"] },
        "isPro": { "type": "boolean", "description": "Whether the user has Pro access." },
        "aiCredits": { "type": "number", "description": "Remaining AI credits." },
        "pwaInstalled": { "type": "boolean", "description": "Whether the user has installed the PWA." },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "email", "role", "isPro", "createdAt"]
    },
    "Post": {
      "title": "Post",
      "description": "A community forum post.",
      "type": "object",
      "properties": {
        "authorId": { "type": "string" },
        "authorName": { "type": "string" },
        "authorPhoto": { "type": "string", "format": "uri" },
        "content": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "likesCount": { "type": "number" },
        "commentsCount": { "type": "number" }
      },
      "required": ["authorId", "authorName", "content", "createdAt", "likesCount", "commentsCount"]
    },
    "Comment": {
      "title": "Comment",
      "description": "A comment on a community post.",
      "type": "object",
      "properties": {
        "postId": { "type": "string" },
        "authorId": { "type": "string" },
        "authorName": { "type": "string" },
        "authorPhoto": { "type": "string", "format": "uri" },
        "content": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["postId", "authorId", "authorName", "content", "createdAt"]
    },
    "Quiz": {
      "title": "Quiz",
      "description": "An educational quiz.",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "description": { "type": "string" },
        "category": { "type": "string" },
        "timeLimit": { "type": "number", "description": "Time limit in minutes." },
        "isProOnly": { "type": "boolean" },
        "questions": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "text": { "type": "string" },
              "type": { "type": "string", "enum": ["multiple-choice", "true-false"] },
              "options": { "type": "array", "items": { "type": "string" } },
              "correctAnswer": { "type": "string" }
            },
            "required": ["text", "type", "correctAnswer"]
          }
        },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["title", "category", "timeLimit", "isProOnly", "questions", "createdAt"]
    },
    "QuizResult": {
      "title": "QuizResult",
      "description": "A student's result on a quiz.",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "quizId": { "type": "string" },
        "score": { "type": "number" },
        "total": { "type": "number" },
        "completedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "quizId", "score", "total", "completedAt"]
    },
    "Note": {
      "title": "Note",
      "description": "An educational note or past paper.",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "content": { "type": "string" },
        "category": { "type": "string" },
        "isProOnly": { "type": "boolean" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["title", "content", "category", "isProOnly", "createdAt"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": { "$ref": "#/entities/User" },
      "description": "User profiles."
    },
    "/posts/{postId}": {
      "schema": { "$ref": "#/entities/Post" },
      "description": "Community posts."
    },
    "/posts/{postId}/comments/{commentId}": {
      "schema": { "$ref": "#/entities/Comment" },
      "description": "Comments on a post."
    },
    "/quizzes/{quizId}": {
      "schema": { "$ref": "#/entities/Quiz" },
      "description": "Educational quizzes."
    },
    "/quizResults/{resultId}": {
      "schema": { "$ref": "#/entities/QuizResult" },
      "description": "Student quiz results."
    },
    "/notes/{noteId}": {
      "schema": { "$ref": "#/entities/Note" },
      "description": "Educational notes and past papers."
    }
  }
}
