rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Helper Functions
    // ===============================================================
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }
    
    function isAdmin() {
      return isAuthenticated() && 
        (
          (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin') ||
          ((request.auth.token.email == "petedianotech@gmail.com" || request.auth.token.email == "mscepreparation@gmail.com") && request.auth.token.email_verified == true)
        );
    }
    
    function hasOnlyAllowedFields(fields) {
      return request.resource.data.keys().hasOnly(fields);
    }

    function hasRequiredFields(fields) {
      return request.resource.data.keys().hasAll(fields);
    }

    function isValidString(field, minLen, maxLen) {
      return request.resource.data[field] is string &&
             request.resource.data[field].size() >= minLen &&
             request.resource.data[field].size() <= maxLen;
    }
    
    function isValidOptionalString(field, minLen, maxLen) {
      return !(field in request.resource.data) ||
             (request.resource.data[field] is string &&
              request.resource.data[field].size() >= minLen &&
              request.resource.data[field].size() <= maxLen);
    }

    // ===============================================================
    // Domain Validators
    // ===============================================================
    function isValidUser(data) {
      return hasOnlyAllowedFields(['uid', 'email', 'displayName', 'photoURL', 'role', 'isPro', 'isGuest', 'aiCredits', 'streak', 'coins', 'lastCreditReset', 'pwaInstalled', 'referralCode', 'referredBy', 'referralsCount', 'createdAt', 'securityQuestions']) &&
             hasRequiredFields(['uid', 'email', 'role', 'isPro', 'createdAt']) &&
             data.uid is string && data.uid.size() > 0 && data.uid.size() < 100 &&
             data.email is string && data.email.size() > 0 && data.email.size() < 100 &&
             data.role in ['student', 'admin'] &&
             data.isPro is bool &&
             data.createdAt is timestamp &&
             isValidOptionalString('displayName', 1, 100) &&
             isValidOptionalString('photoURL', 1, 500) &&
             (!('isGuest' in data) || data.isGuest is bool) &&
             (!('aiCredits' in data) || data.aiCredits is number) &&
             (!('streak' in data) || data.streak is number) &&
             (!('coins' in data) || data.coins is number) &&
             (!('lastCreditReset' in data) || data.lastCreditReset is string) &&
             (!('pwaInstalled' in data) || data.pwaInstalled is bool) &&
             (!('referralCode' in data) || data.referralCode is string) &&
             (!('referredBy' in data) || data.referredBy is string) &&
             (!('referralsCount' in data) || data.referralsCount is number) &&
             (!('securityQuestions' in data) || data.securityQuestions is list);
    }

    function isValidChatMessage(data) {
      return hasOnlyAllowedFields(['authorId', 'authorName', 'authorPhoto', 'content', 'createdAt']) &&
             hasRequiredFields(['authorId', 'authorName', 'content', 'createdAt']) &&
             data.authorId is string && data.authorId.size() > 0 && data.authorId.size() < 100 &&
             data.authorName is string && data.authorName.size() > 0 && data.authorName.size() < 100 &&
             data.content is string && data.content.size() > 0 && data.content.size() < 2000 &&
             data.createdAt is timestamp &&
             isValidOptionalString('authorPhoto', 1, 500);
    }

    function isValidPost(data) {
      return hasOnlyAllowedFields(['authorId', 'authorName', 'authorPhoto', 'content', 'createdAt', 'likesCount', 'likedBy', 'commentsCount']) &&
             hasRequiredFields(['authorId', 'authorName', 'content', 'createdAt', 'likesCount', 'commentsCount']) &&
             data.authorId is string && data.authorId.size() > 0 && data.authorId.size() < 100 &&
             data.authorName is string && data.authorName.size() > 0 && data.authorName.size() < 100 &&
             data.content is string && data.content.size() > 0 && data.content.size() < 5000 &&
             data.createdAt is timestamp &&
             data.likesCount is number &&
             data.commentsCount is number &&
             (!('likedBy' in data) || data.likedBy is list) &&
             isValidOptionalString('authorPhoto', 1, 500);
    }

    function isValidReply(data) {
      return hasOnlyAllowedFields(['postId', 'authorId', 'authorName', 'authorPhoto', 'content', 'createdAt']) &&
             hasRequiredFields(['postId', 'authorId', 'authorName', 'content', 'createdAt']) &&
             data.postId is string && data.postId.size() > 0 && data.postId.size() < 100 &&
             data.authorId is string && data.authorId.size() > 0 && data.authorId.size() < 100 &&
             data.authorName is string && data.authorName.size() > 0 && data.authorName.size() < 100 &&
             data.content is string && data.content.size() > 0 && data.content.size() < 2000 &&
             data.createdAt is timestamp &&
             isValidOptionalString('authorPhoto', 1, 500);
    }

    function isValidQuizResult(data) {
      return hasOnlyAllowedFields(['userId', 'quizId', 'quizTitle', 'score', 'total', 'completedAt']) &&
             hasRequiredFields(['userId', 'quizId', 'quizTitle', 'score', 'total', 'completedAt']) &&
             data.userId is string && data.userId.size() > 0 && data.userId.size() < 100 &&
             data.quizId is string && data.quizId.size() > 0 && data.quizId.size() < 100 &&
             data.quizTitle is string && data.quizTitle.size() > 0 && data.quizTitle.size() < 200 &&
             data.score is number && data.score >= 0 &&
             data.total is number && data.total > 0 &&
             data.completedAt is timestamp;
    }

    function isValidQuiz(data) {
      return hasOnlyAllowedFields(['title', 'description', 'category', 'authorId', 'timeLimit', 'isProOnly', 'questions', 'createdAt']) &&
             hasRequiredFields(['title', 'category', 'authorId', 'timeLimit', 'isProOnly', 'questions', 'createdAt']) &&
             data.title is string && data.title.size() > 0 && data.title.size() < 200 &&
             data.category is string && data.category.size() > 0 && data.category.size() < 100 &&
             data.authorId is string && data.authorId.size() > 0 && data.authorId.size() < 100 &&
             data.timeLimit is number && data.timeLimit > 0 &&
             data.isProOnly is bool &&
             data.questions is list && data.questions.size() > 0 && data.questions.size() <= 100 &&
             data.createdAt is timestamp &&
             isValidOptionalString('description', 0, 1000);
    }

    function isValidNote(data) {
      return hasOnlyAllowedFields(['title', 'content', 'category', 'isProOnly', 'createdAt', 'driveUrl', 'youtubeUrl']) &&
             hasRequiredFields(['title', 'category', 'isProOnly', 'createdAt']) &&
             data.title is string && data.title.size() > 0 && data.title.size() < 200 &&
             data.category is string && data.category.size() > 0 && data.category.size() < 100 &&
             data.isProOnly is bool &&
             data.createdAt is timestamp &&
             isValidOptionalString('content', 0, 50000) &&
             isValidOptionalString('driveUrl', 1, 1000) &&
             isValidOptionalString('youtubeUrl', 1, 1000);
    }

    function isValidAppUpdate(data) {
      return hasOnlyAllowedFields(['title', 'content', 'type', 'createdAt']) &&
             hasRequiredFields(['title', 'content', 'type', 'createdAt']) &&
             data.title is string && data.title.size() > 0 && data.title.size() < 200 &&
             data.content is string && data.content.size() > 0 && data.content.size() < 5000 &&
             data.type in ['feature', 'maintenance', 'announcement'] &&
             data.createdAt is timestamp;
    }

    function isValidRevenueRecord(data) {
      return hasOnlyAllowedFields(['userId', 'userName', 'amount', 'plan', 'createdAt']) &&
             hasRequiredFields(['userId', 'userName', 'amount', 'plan', 'createdAt']) &&
             data.userId is string && data.userId.size() > 0 && data.userId.size() < 100 &&
             data.userName is string && data.userName.size() > 0 && data.userName.size() < 100 &&
             data.amount is number && data.amount >= 0 &&
             data.plan is string && data.plan.size() > 0 && data.plan.size() < 50 &&
             data.createdAt is timestamp;
    }

    function isValidExamDate(data) {
      return hasOnlyAllowedFields(['subject', 'date', 'description', 'createdAt']) &&
             hasRequiredFields(['subject', 'date', 'createdAt']) &&
             data.subject is string && data.subject.size() > 0 && data.subject.size() < 200 &&
             data.date is timestamp &&
             data.createdAt is timestamp &&
             isValidOptionalString('description', 0, 1000);
    }

    function isValidFlashcardSet(data) {
      return hasOnlyAllowedFields(['title', 'description', 'category', 'authorId', 'authorName', 'isProOnly', 'createdAt']) &&
             hasRequiredFields(['title', 'category', 'authorId', 'authorName', 'isProOnly', 'createdAt']) &&
             data.title is string && data.title.size() > 0 && data.title.size() < 200 &&
             data.category is string && data.category.size() > 0 && data.category.size() < 100 &&
             data.authorId is string && data.authorId.size() > 0 && data.authorId.size() < 100 &&
             data.authorName is string && data.authorName.size() > 0 && data.authorName.size() < 100 &&
             data.isProOnly is bool &&
             data.createdAt is timestamp &&
             isValidOptionalString('description', 0, 1000);
    }

    function isValidFlashcard(data) {
      return hasOnlyAllowedFields(['setId', 'front', 'back', 'createdAt']) &&
             hasRequiredFields(['setId', 'front', 'back', 'createdAt']) &&
             data.setId is string && data.setId.size() > 0 && data.setId.size() < 100 &&
             data.front is string && data.front.size() > 0 && data.front.size() < 1000 &&
             data.back is string && data.back.size() > 0 && data.back.size() < 1000 &&
             data.createdAt is timestamp;
    }

    // ===============================================================
    // Rules
    // ===============================================================
    match /users/{userId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && isValidUser(request.resource.data) && 
                    isOwner(userId) && request.resource.data.uid == userId;
      allow update: if isAuthenticated() && isValidUser(request.resource.data) &&
                    ((isOwner(userId) && request.resource.data.uid == resource.data.uid && 
                      request.resource.data.role == resource.data.role && 
                      request.resource.data.isPro == resource.data.isPro &&
                      request.resource.data.createdAt == resource.data.createdAt) || isAdmin());
    }

    match /recovery/{identifier} {
      allow get: if true;
      allow create: if isAuthenticated() && request.auth.uid == request.resource.data.uid;
      allow update: if isAuthenticated() && request.auth.uid == resource.data.uid;
      allow delete: if isAdmin();
    }

    match /messages/{messageId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && isValidChatMessage(request.resource.data) && 
                    request.resource.data.authorId == request.auth.uid;
      allow delete: if isAuthenticated() && (request.auth.uid == resource.data.authorId || isAdmin());
    }

    match /posts/{postId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && isValidPost(request.resource.data) && 
                    request.resource.data.authorId == request.auth.uid &&
                    request.resource.data.likesCount == 0 &&
                    request.resource.data.commentsCount == 0;
      allow update: if isAuthenticated() && isValidPost(request.resource.data) &&
                    ((request.resource.data.authorId == resource.data.authorId &&
                      request.resource.data.createdAt == resource.data.createdAt &&
                      (request.auth.uid == resource.data.authorId || 
                       (request.resource.data.diff(resource.data).affectedKeys().hasOnly(['likesCount', 'commentsCount', 'likedBy'])))) || isAdmin());
      allow delete: if isAuthenticated() && (request.auth.uid == resource.data.authorId || isAdmin());
    }

    match /replies/{replyId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && isValidReply(request.resource.data) && 
                    request.resource.data.authorId == request.auth.uid;
      allow update: if isAuthenticated() && isValidReply(request.resource.data) &&
                    ((request.resource.data.authorId == resource.data.authorId &&
                      request.resource.data.createdAt == resource.data.createdAt &&
                      request.auth.uid == resource.data.authorId) || isAdmin());
      allow delete: if isAuthenticated() && (request.auth.uid == resource.data.authorId || isAdmin());
    }

    match /quizResults/{resultId} {
      allow read: if isAuthenticated() && (request.auth.uid == resource.data.userId || isAdmin());
      allow create: if isAuthenticated() && isValidQuizResult(request.resource.data) && 
                    request.resource.data.userId == request.auth.uid;
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }

    match /quizzes/{quizId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && isValidQuiz(request.resource.data) && 
                    (request.resource.data.authorId == request.auth.uid || isAdmin());
      allow update: if isAuthenticated() && isValidQuiz(request.resource.data) &&
                    (resource.data.authorId == request.auth.uid || isAdmin());
      allow delete: if isAuthenticated() && (resource.data.authorId == request.auth.uid || isAdmin());
    }

    match /notes/{noteId} {
      allow read: if isAuthenticated();
      allow create: if isAdmin() && isValidNote(request.resource.data);
      allow update: if isAdmin() && isValidNote(request.resource.data);
      allow delete: if isAdmin();
    }

    match /appUpdates/{updateId} {
      allow read: if true;
      allow create: if isAdmin() && isValidAppUpdate(request.resource.data);
      allow update: if isAdmin() && isValidAppUpdate(request.resource.data);
      allow delete: if isAdmin();
    }

    match /revenue/{recordId} {
      allow read: if isAdmin();
      allow create: if isAuthenticated() && isValidRevenueRecord(request.resource.data) && 
                    (request.resource.data.userId == request.auth.uid || isAdmin());
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }

    match /examDates/{dateId} {
      allow read: if true;
      allow create: if isAdmin() && isValidExamDate(request.resource.data);
      allow update: if isAdmin() && isValidExamDate(request.resource.data);
      allow delete: if isAdmin();
    }

    match /flashcardSets {
      allow list: if isAuthenticated();
      match /{setId} {
        allow get: if isAuthenticated();
        allow create: if isAuthenticated() && isValidFlashcardSet(request.resource.data) && 
                      (request.resource.data.authorId == request.auth.uid || isAdmin());
        allow update: if isAuthenticated() && isValidFlashcardSet(request.resource.data) &&
                      (resource.data.authorId == request.auth.uid || isAdmin());
        allow delete: if isAuthenticated() && (resource.data.authorId == request.auth.uid || isAdmin());
      }
    }

    match /flashcards/{cardId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && isValidFlashcard(request.resource.data);
      allow update: if isAuthenticated() && isValidFlashcard(request.resource.data);
      allow delete: if isAuthenticated() && (isAdmin() || (exists(/databases/$(database)/documents/flashcardSets/$(resource.data.setId)) && get(/databases/$(database)/documents/flashcardSets/$(resource.data.setId)).data.authorId == request.auth.uid));
    }
  }
}
